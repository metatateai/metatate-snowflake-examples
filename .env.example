# Offline mode is the default.
METATATE_EXAMPLES_MODE=offline

# Live mode uses the Snowflake Native App canonical SQL tool layer.
# Set METATATE_EXAMPLES_MODE=live after these values are configured.
SNOWFLAKE_ACCOUNT=your-org-your-account
SNOWFLAKE_USER=you@example.com
SNOWFLAKE_ROLE=NAC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_AUTHENTICATOR=externalbrowser
METATATE_APP_NAME=METATATE_APP

